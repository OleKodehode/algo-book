*   [inf    12    11    16]
*   [15    inf    15    10]
*   [8      14   inf    18]
*   [9      11    17   inf]
*   best at the end: 44
*/

// Simplified (for now)
function branchAndBound(costMatrix) {
  n = costMatrix.length
  bestCost = Infinity
  bestPath = null

  // Start with a RCM calculation of the start/root node
  initialRCM = reduceMatrix(costMatrix)
  initialLowerBound = calculateLowerBound(initialRCM)

  // Recursive branch function
  function branch(currentPath, currentCost, rcm, level) {
    if (level == n) {
      // last level - return out
      last = currentPath[level-1]
      frist = currentPath[0]
      tourCost = currentCost + costMatrix[last][first]
      if (tourCost < bestCost) {
        bestCost = tourCost
        bestPath = [...currentPath, first]
      }
      return
    }

    for (next = 0; next < n; next++) {
      if (currentPath.includes(next)) continue // already visited

      // Compute new recuded matrix for this branch
      newRCM = createChildRCM(rm, currentPath[level-1], next)
      newLB = currentCost + calculateLowerBound(newRCM)

      if (newLB >= bestCost) continue // no need to keep this

      currentPath.push(next)
      nextCost = currentCost + costMatrix[currentPath[level-1]][next]
      branch(currentPath, nextCost, newRCM, level + 1)
      currentPath.pop() // Backtracking
    }
  }

  branch([0], 0, initialRCM, 1) // Start from city 0

  return { cost: bestCost, path: bestPath}
}

